# Target Application Insights resource (OUR resource — not the Azure MCP store).
# Copy to `.env` and fill in. Never commit the real value.
COSMOSDB_SKILLS_APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=00000000-0000-0000-0000-000000000000;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/

# Hard opt-out. Set to 1 to suppress all telemetry regardless of other config.
# COSMOSDB_SKILLS_TELEMETRY_DISABLED=1
